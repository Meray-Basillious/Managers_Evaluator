NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=managers_evaluator

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars_here
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# File Storage (S3 or MinIO)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=managers-evaluator
S3_ENDPOINT=http://localhost:9000

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=noreply@managers-evaluator.com

# AI Engine
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_API_KEY=your-api-key

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Monitoring
SENTRY_DSN=

# Feature Flags
FEATURE_AI_ANALYSIS=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_REAL_TIME_COLLABORATION=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000
